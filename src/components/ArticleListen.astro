---
interface Props {
	audioUrl?: string;
}

const { audioUrl } = Astro.props;
---

<div
	class="article-listen"
	data-article-listen
	data-audio-url={audioUrl}
	hidden
>
	<button
		type="button"
		class="article-listen__btn"
		data-article-listen-toggle
		aria-pressed="false"
		aria-label="ฟังข่าวนี้อ่านออกเสียง"
	>
		<svg
			class="article-listen__icon"
			width="18"
			height="18"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
			<path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
			<path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
		</svg>
		<span data-article-listen-label>ฟังข่าว</span>
	</button>
	<audio data-article-listen-audio preload="none" hidden></audio>
	<p class="article-listen__hint" data-article-listen-hint hidden>
		เสียงอ่านโดย Microsoft Neural TTS (ภาษาไทย)
	</p>
</div>

<script>
	function initArticleListen(root: HTMLElement) {
		const toggle = root.querySelector<HTMLButtonElement>('[data-article-listen-toggle]');
		const label = root.querySelector('[data-article-listen-label]');
		const hint = root.querySelector<HTMLElement>('[data-article-listen-hint]');
		const audioEl = root.querySelector<HTMLAudioElement>('[data-article-listen-audio]');
		const audioUrl = root.dataset.audioUrl;

		if (!toggle || !label || !hint || !audioEl || !audioUrl) {
			return;
		}

		root.hidden = false;
		audioEl.src = audioUrl;
		audioEl.hidden = false;
		hint.hidden = false;

		const setPlaying = (playing: boolean) => {
			toggle.setAttribute('aria-pressed', String(playing));
			toggle.setAttribute('aria-label', playing ? 'หยุดฟังข่าว' : 'ฟังข่าวนี้อ่านออกเสียง');
			label.textContent = playing ? 'หยุดฟัง' : 'ฟังข่าว';
			root.classList.toggle('article-listen--playing', playing);
		};

		const stop = () => {
			audioEl.pause();
			audioEl.currentTime = 0;
			setPlaying(false);
		};

		toggle.addEventListener('click', () => {
			if (!audioEl.paused) {
				stop();
				return;
			}

			audioEl.play().then(
				() => setPlaying(true),
				() => setPlaying(false),
			);
		});

		audioEl.addEventListener('ended', () => setPlaying(false));
		audioEl.addEventListener('pause', () => {
			if (audioEl.currentTime > 0 && !audioEl.ended) {
				setPlaying(false);
			}
		});

		window.addEventListener('pagehide', stop);
		document.addEventListener('astro:before-preparation', stop);
	}

	for (const root of document.querySelectorAll<HTMLElement>('[data-article-listen]')) {
		initArticleListen(root);
	}
</script>
