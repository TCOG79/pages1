---
import Layout from '../../layouts/Layout.astro';
import Masthead from '../../components/Masthead.astro';
import { SITE_NAME } from '../../config/site';
---

<Layout title="นโยบายลิขสิทธิ์" description={`นโยบายลิขสิทธิ์ของ ${SITE_NAME}`}>
	<Masthead />
	<main class="legal-page">
		<div class="container">
			<a class="article-page__back" href="/">&larr; กลับหน้าหลัก</a>

			<h1 class="legal-page__title">นโยบายลิขสิทธิ์</h1>

			<div class="legal-page__content">
				<p>
					{SITE_NAME} เคารพสิทธิในทรัพย์สินทางปัญญาของเจ้าของเนื้อหาต้นฉบับ
					และดำเนินการตามหลักการรายงานข่าวตามพระราชบัญญัติลิขสิทธิ์ พ.ศ. 2537
				</p>

				<h2>สิ่งที่เราทำ</h2>
				<ul>
					<li>สรุปข่าวสั้น 2–3 ย่อหน้า จากบทความต้นทาง</li>
					<li>ระบุชื่อสำนักข่าวและลิงก์ไปยังบทความต้นฉบับทุกข่าว</li>
					<li>ใช้ canonical URL ชี้ไปยังหน้าสรุปของ {SITE_NAME} และระบุลิงก์บทความต้นฉบับชัดเจน</li>
					<li>ไม่คัดลอกบทความฉบับเต็มโดยไม่ได้รับอนุญาต</li>
					<li>ใช้รูปภาพ thumbnail จากต้นทาง พร้อมเครดิตและลิงก์ไปบทความต้นฉบับ</li>
				</ul>

				<h2>นโยบายรูปภาพ</h2>
				<ul>
					<li>ดาวน์โหลดรูป lead image จากต้นทาง เก็บเป็น thumbnail (กว้างไม่เกิน 800px)</li>
					<li>ระบุเครดิตรูปเสมอ เช่น "ภาพ: ฐานเศรษฐกิจ"</li>
					<li>คลิกรูปหรือเครดิตเพื่อไปยังบทความต้นฉบับ</li>
					<li>ข่าวแจกแจง/PR ที่อนุญาตใช้ซ้ำ จัดประเภทเป็น press release</li>
					<li>หากดึงรูปไม่ได้ ใช้ placeholder แทน</li>
				</ul>

				<h2>สิ่งที่เราไม่ทำ</h2>
				<ul>
					<li>ไม่อ้างสิทธิ์เป็นเจ้าของเนื้อหาข่าวจากสำนักข่าวอื่น</li>
					<li>ไม่ hotlink รูปจาก CDN สำนักข่าวโดยตรง</li>
					<li>ไม่ใช้รูปความละเอียดเต็มโดยไม่ย่อ</li>
					<li>ไม่แก้ไขความหมายของข่าวต้นทาง</li>
				</ul>

				<h2>ลิขสิทธิ์ของเว็บไซต์</h2>
				<p>
					การออกแบบ โครงสร้าง และโค้ดของเว็บไซต์ {SITE_NAME} เป็นทรัพย์สินของผู้ดำเนินการเว็บไซต์
					เนื้อหาข่าวที่สรุปจากแหล่งภายนอกยังคงเป็นสิทธิของเจ้าของต้นฉบับ
				</p>

				<h2>การใช้งานเนื้อหา</h2>
				<p>
					หากต้องการใช้เนื้อหาข่าว กรุณาติดต่อสำนักข่าวต้นทางโดยตรง
					หากเป็นเจ้าของลิขสิทธิ์และต้องการให้ลบหรือแก้ไขเนื้อหา ดูรายละเอียดที่
					<a href="/legal/takedown/">แจ้งลบเนื้อหา</a>
				</p>

				<p class="legal-page__updated">อัปเดตล่าสุด: 10 มิถุนายน 2569</p>
			</div>

			<nav class="legal-page__nav" aria-label="หน้ากฎหมาย">
				<a href="/legal/disclaimer/">ข้อจำกัดความรับผิดชอบ</a>
				<a href="/legal/takedown/">แจ้งลบเนื้อหา</a>
			</nav>
		</div>
	</main>
</Layout>
