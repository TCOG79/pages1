---
import Layout from '../../layouts/Layout.astro';
import Masthead from '../../components/Masthead.astro';
import { SITE_NAME } from '../../config/site';
---

<Layout title="ข้อจำกัดความรับผิดชอบ" description={`ข้อจำกัดความรับผิดชอบของ ${SITE_NAME}`}>
	<Masthead />
	<main class="legal-page">
		<div class="container">
			<a class="article-page__back" href="/">&larr; กลับหน้าหลัก</a>

			<h1 class="legal-page__title">ข้อจำกัดความรับผิดชอบ</h1>

			<div class="legal-page__content">
				<p>
					{SITE_NAME} เป็นเว็บไซต์สรุปข่าวจากแหล่งข่าวภายนอก เนื้อหาที่แสดงบนเว็บไซต์นี้เป็นการสรุปย่อ
					ไม่ใช่การคัดลอกบทความฉบับเต็มจากสำนักข่าวต้นทาง
				</p>

				<h2>เนื้อหาข่าว</h2>
				<p>
					ลิขสิทธิ์ของเนื้อหาข่าว รูปภาพ และสื่อประกอบบทความฉบับเต็มเป็นของสำนักข่าวต้นทาง
					ผู้ใช้งานควรอ่านบทความฉบับเต็มจากลิงก์ต้นทางที่ระบุในแต่ละข่าว
				</p>

				<h2>ความถูกต้องของข้อมูล</h2>
				<p>
					เราพยายามสรุปข่าวให้ตรงกับต้นทางและระบุแหล่งอ้างอิงเสมอ
					แต่ไม่รับประกันความถูกต้อง ความครบถ้วน หรือความทันสมัยของข้อมูลทั้งหมด
					หากพบข้อผิดพลาด กรุณาอ้างอิงบทความต้นฉบับเป็นหลัก
				</p>

				<h2>ลิงก์ภายนอก</h2>
				<p>
					เว็บไซต์มีลิงก์ไปยังเว็บไซต์ภายนอก เราไม่รับผิดชอบต่อเนื้อหา นโยบายความเป็นส่วนตัว
					หรือการปฏิบัติของเว็บไซต์เหล่านั้น
				</p>

				<p class="legal-page__updated">อัปเดตล่าสุด: 10 มิถุนายน 2569</p>
			</div>

			<nav class="legal-page__nav" aria-label="หน้ากฎหมาย">
				<a href="/legal/copyright/">นโยบายลิขสิทธิ์</a>
				<a href="/legal/takedown/">แจ้งลบเนื้อหา</a>
			</nav>
		</div>
	</main>
</Layout>
